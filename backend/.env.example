GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_service_role_key_here
MOD_TEMPLATE_DIR=../mod-template
TEMP_DIR_BASE=/tmp/modcreator
MAX_FIX_ITERATIONS=3
BUILD_TIMEOUT_SECONDS=300

# CurseForge API (free key from console.curseforge.com)
CURSEFORGE_API_KEY=your_curseforge_api_key_here

# Payment gateway: "razorpay" or "dodo"
PAYMENT_GATEWAY=razorpay

# Razorpay (https://dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
RAZORPAY_PLAN_BASIC_WEEKLY=plan_weekly_id
RAZORPAY_PLAN_BASIC_MONTHLY=plan_monthly_id
RAZORPAY_PLAN_UNLIMITED_MONTHLY=plan_unlimited_id

# DodoPayments (alternative gateway)
DODO_PAYMENTS_API_KEY=your_dodo_api_key
DODO_PAYMENTS_WEBHOOK_KEY=your_dodo_webhook_key
DODO_PAYMENTS_ENVIRONMENT=test_mode
DODO_PRODUCT_BASIC_WEEKLY=prod_weekly_id
DODO_PRODUCT_BASIC_MONTHLY=prod_monthly_id
DODO_PRODUCT_UNLIMITED_MONTHLY=prod_unlimited_id
