# Copy this file to .env.local and fill in the values.

# Backend API base URL. Required — the frontend calls ${NEXT_PUBLIC_API_URL}/api/*.
# If unset, API_BASE falls back to "" (same-origin) and every request 404s against Next.
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Supabase (anon key only — never commit the service role key here)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# ----- Ad monetization -----
# Provider priority: Ezoic > AdSense > Adsterra.
# AdSlot picks the first one configured. If Ezoic is set, we still emit
# AdSense markup (Ezoic intercepts AdSense ins tags automatically).

# Google AdSense (leave blank until AdSense approval lands)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxxxxxxxxxx

# Ezoic (requires a real owned domain — won't work on *.vercel.app)
NEXT_PUBLIC_EZOIC_SITE_ID=

# Adsterra zone keys and full invoke.js URLs.
# Create these in https://beta.publishers.adsterra.com → Websites → Ad Unit
# Copy the "Get Code" script and extract both the key (the hex string inside
# the URL) and the full https://.../invoke.js URL. The native format uses a
# different CDN subdomain than banner, so we can't reconstruct the URL from
# the key alone — paste the whole URL.
# NEVER set a popunder/interstitial/social-bar zone here. Banner + Native only.
NEXT_PUBLIC_ADSTERRA_BANNER_KEY=
NEXT_PUBLIC_ADSTERRA_BANNER_SCRIPT=
NEXT_PUBLIC_ADSTERRA_NATIVE_KEY=
NEXT_PUBLIC_ADSTERRA_NATIVE_SCRIPT=
